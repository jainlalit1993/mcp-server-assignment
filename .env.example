# Copy this file to .env and fill in your keys.   cp .env.example .env

# OpenAI — used for every LLM call.
OPENAI_API_KEY=

# GitHub personal access token (read-only is enough). Used ONLY by the GitHub MCP server.
GITHUB_TOKEN=

# Models: cheap model for guard/format nodes, strong model for reasoning.
FAST_MODEL=gpt-4o-mini
SMART_MODEL=gpt-4o

# GitHub MCP server (remote, default). Streamable HTTP transport.
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# Transport for the GitHub MCP server: "streamable_http" (remote, default) or "stdio" (local Docker server).
GITHUB_MCP_TRANSPORT=streamable_http
